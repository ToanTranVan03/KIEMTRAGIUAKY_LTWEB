@using TOEIC.Web.Startup
@model List<TOEIC.Exams.Dto.ExamDto>
@{
    ViewBag.Title = "Thư viện đề thi TOEIC";
    ViewBag.CurrentPageName = PageNames.Test;
}

<style>
    .test-library-page {
        padding: 32px 0 40px;
        background:
            radial-gradient(circle at top left, rgba(18, 146, 137, 0.18), transparent 32%),
            radial-gradient(circle at top right, rgba(37, 99, 235, 0.16), transparent 28%),
            linear-gradient(180deg, #f4f8fc 0%, #edf4f7 52%, #f8fbfd 100%);
    }

    .test-library-hero {
        background: linear-gradient(135deg, #153a5b 0%, #0f6d7a 58%, #23a4b5 100%);
        border-radius: 28px;
        padding: 32px;
        color: #fff;
        box-shadow: 0 28px 60px rgba(13, 48, 80, 0.20);
        position: relative;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .test-library-hero::after {
        content: "";
        position: absolute;
        inset: auto -80px -120px auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.10);
    }

    .test-library-kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .test-library-title {
        font-size: 40px;
        line-height: 1.1;
        font-weight: 800;
        margin: 0 0 12px;
        max-width: 640px;
    }

    .test-library-subtitle {
        max-width: 620px;
        font-size: 17px;
        line-height: 1.7;
        margin: 0;
        color: rgba(255, 255, 255, 0.88);
    }

    .library-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .summary-card {
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(181, 199, 214, 0.55);
        border-radius: 22px;
        padding: 20px 22px;
        box-shadow: 0 18px 40px rgba(31, 55, 86, 0.08);
    }

    .summary-card .label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: #6c8195;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .summary-card .value {
        display: block;
        font-size: 30px;
        line-height: 1;
        font-weight: 800;
        color: #16334d;
        margin-bottom: 8px;
    }

    .summary-card .hint {
        color: #597086;
        margin: 0;
        font-size: 14px;
    }

    .exam-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .exam-card {
        background: rgba(255, 255, 255, 0.90);
        border: 1px solid rgba(190, 206, 220, 0.64);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(28, 54, 84, 0.10);
        transition: transform 0.22s ease, box-shadow 0.22s ease;
        height: 100%;
    }

    .exam-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 26px 48px rgba(28, 54, 84, 0.16);
    }

    .exam-card-top {
        padding: 18px 20px 14px;
        background: linear-gradient(135deg, #eff7fb 0%, #f8fbff 100%);
        border-bottom: 1px solid rgba(203, 216, 228, 0.8);
    }

    .exam-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        background: rgba(21, 58, 91, 0.08);
        color: #18516d;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .exam-title {
        font-size: 21px;
        line-height: 1.35;
        font-weight: 800;
        color: #132f49;
        margin: 0;
        min-height: 56px;
    }

    .exam-card-body {
        padding: 20px;
    }

    .exam-description {
        color: #5d7287;
        line-height: 1.7;
        min-height: 72px;
        margin-bottom: 18px;
    }

    .exam-meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .exam-meta-item {
        background: #f5f9fc;
        border: 1px solid #dfe8ef;
        border-radius: 16px;
        padding: 14px 16px;
    }

    .exam-meta-item .meta-label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        color: #6c8195;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .exam-meta-item .meta-value {
        display: block;
        font-size: 18px;
        font-weight: 800;
        color: #153a5b;
    }

    .exam-cta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding-top: 16px;
        border-top: 1px solid #e4edf3;
    }

    .exam-cta-text {
        color: #607487;
        font-size: 14px;
        line-height: 1.6;
        margin: 0;
    }

    .btn-start-exam {
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg, #16436a 0%, #14868a 100%);
        color: #fff;
        font-weight: 700;
        padding: 12px 18px;
        box-shadow: 0 16px 30px rgba(20, 102, 116, 0.24);
    }

    .btn-start-exam:hover,
    .btn-start-exam:focus {
        color: #fff;
        box-shadow: 0 18px 32px rgba(20, 102, 116, 0.28);
    }

    .empty-library {
        background: rgba(255, 255, 255, 0.88);
        border: 1px dashed #bfd0dc;
        border-radius: 24px;
        padding: 48px 32px;
        text-align: center;
        color: #587084;
        box-shadow: 0 20px 40px rgba(28, 54, 84, 0.08);
    }

    .empty-library i {
        font-size: 44px;
        color: #16858b;
        margin-bottom: 16px;
    }

    @@media (max-width: 991.98px) {
        .library-summary,
        .exam-grid {
            grid-template-columns: 1fr;
        }

        .test-library-title {
            font-size: 32px;
        }
    }
</style>

<section class="content test-library-page">
    <div class="container-fluid">
        <div class="test-library-hero">
            <div class="test-library-kicker">
                <i class="fas fa-book-reader"></i>
                Toeic Reading Hub
            </div>
            <h1 class="test-library-title">Thư viện đề thi TOEIC Reading cho người học và luyện đề</h1>
            <p class="test-library-subtitle">
                Chọn một đề thi phù hợp, vào làm bài ngay và theo dõi tiến độ luyện tập của bạn trong một không gian rõ ràng, tập trung và dễ sử dụng.
            </p>
        </div>

        <div class="library-summary">
            <div class="summary-card">
                <span class="label">Tổng số đề</span>
                <span class="value">@Model.Count</span>
                <p class="hint">Tất cả đề đã sẵn sàng để bạn bắt đầu ngay.</p>
            </div>
            <div class="summary-card">
                <span class="label">Mục tiêu</span>
                <span class="value">495</span>
                <p class="hint">Hệ thống tập trung vào luyện tập reading đúng cấu trúc TOEIC.</p>
            </div>
            <div class="summary-card">
                <span class="label">Loại bài</span>
                <span class="value">Part 5-7</span>
                <p class="hint">Bao gồm incomplete sentences, text completion và reading comprehension.</p>
            </div>
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty-library">
                <i class="fas fa-folder-open"></i>
                <h3>Chưa có đề thi được xuất bản</h3>
                <p class="mb-0">Quản trị viên cần đăng tải và kích hoạt đề thi trước khi người dùng có thể vào làm bài.</p>
            </div>
        }
        else
        {
            <div class="exam-grid">
                @foreach (var exam in Model)
                {
                    var description = "\u0110ề thi sẵn sàng cho một lần luyện tập reading đầy đủ, giao diện làm bài sế hiển thị bộ đếm giờ và bảng đánh dấu câu hỏi.";

                    <article class="exam-card">
                        <div class="exam-card-top">
                            <div class="exam-badge">
                                <i class="fas fa-layer-group"></i>
                                TOEIC Reading Test
                            </div>
                            <h2 class="exam-title">@exam.Title</h2>
                        </div>
                        <div class="exam-card-body">
                            <p class="exam-description">@description</p>

                            <div class="exam-meta">
                                <div class="exam-meta-item">
                                    <span class="meta-label">Thời gian</span>
                                    <span class="meta-value">@exam.Duration phút</span>
                                </div>
                                <div class="exam-meta-item">
                                    <span class="meta-label">Số câu hỏi</span>
                                    <span class="meta-value">@exam.QuestionCount câu</span>
                                </div>
                            </div>

                            <div class="exam-cta">
                                <p class="exam-cta-text">Bắt đầu bài thi trong giao diện tập trung, có bộ đếm giờ và diều hướng từng câu.</p>
                                <a href="@Url.Action("Take", new { id = exam.Id })"
                                   class="btn btn-start-exam"
                                   onclick="return confirm('Bạn sẽ vào giao diện làm bài của đề này. Tiếp tục?')">>
                                    <i class="fas fa-play mr-1"></i>
                                    Bắt đầu làm bài
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
