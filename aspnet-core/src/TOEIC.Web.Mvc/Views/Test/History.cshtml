@using TOEIC.Web.Startup
@model List<TOEIC.Exams.Dto.ExamResultDto>
@{
    var canManageExamHistory = ViewBag.CanManageExamHistory is bool value && value;
    ViewBag.Title = canManageExamHistory ? "Lịch sử thi thi sinh" : "Test History";
    ViewBag.CurrentPageName = PageNames.TestHistory;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-history text-info"></i> @(canManageExamHistory ? "Lịch sử thi thi sinh" : "Test History")</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Quay lại danh sách đề thi
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-list"></i> @(canManageExamHistory ? "Tất cả lượt thi" : "Attempts") (@(Model?.Count ?? 0))
                </h3>
            </div>
            <div class="card-body p-0">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="p-4 text-muted">No test attempt found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="thead-dark">
                                <tr>
                                    <th style="width: 80px;">#</th>
                                    <th style="width: 180px;">Thi sinh</th>
                                    <th>Exam</th>
                                    <th style="width: 130px;">Score</th>
                                    <th style="width: 120px;">Correct</th>
                                    <th style="width: 120px;">Wrong</th>
                                    <th style="width: 120px;">Skipped</th>
                                    <th style="width: 190px;">Start Time</th>
                                    <th style="width: 190px;">End Time</th>
                                    <th style="width: 110px;">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.Id</strong></td>
                                        <td>@item.UserName</td>
                                        <td>@item.ExamTitle</td>
                                        <td><span class="badge badge-primary">@item.ExpectedScore / 495</span></td>
                                        <td><span class="text-success font-weight-bold">@item.TotalCorrect</span></td>
                                        <td><span class="text-danger font-weight-bold">@item.TotalWrong</span></td>
                                        <td><span class="text-warning font-weight-bold">@item.TotalSkipped</span></td>
                                        <td>@item.StartTime.ToString("HH:mm:ss dd/MM/yyyy")</td>
                                        <td>@(item.EndTime.HasValue ? item.EndTime.Value.ToString("HH:mm:ss dd/MM/yyyy") : "-")</td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Result", new { id = item.Id })">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
