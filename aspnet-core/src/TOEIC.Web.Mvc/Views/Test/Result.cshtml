@using TOEIC.Web.Startup
@model TOEIC.Exams.Dto.ExamResultDto
@{
    ViewBag.Title = "Kết quả bài thi";
    ViewBag.CurrentPageName = PageNames.Test;
    var totalQuestions = Model.TotalCorrect + Model.TotalWrong + Model.TotalSkipped;
    var percentage = totalQuestions > 0 ? (Model.TotalCorrect * 100.0 / totalQuestions) : 0;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0"><i class="fas fa-chart-bar text-primary"></i> Kết quả bài thi</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="@Url.Action("Index")" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Về danh sách đề
                </a>
                <a href="@Url.Action("History")" class="btn btn-info btn-sm">
                    <i class="fas fa-history"></i> Lịch sử thi
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .result-banner {
        padding: 28px 24px;
        border-radius: 18px;
        background: linear-gradient(135deg, #1f3a8a 0%, #2563eb 100%);
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 20px 50px rgba(15, 29, 52, 0.2);
    }

    .result-banner__title {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .result-banner__meta {
        margin-top: 10px;
        color: rgba(255, 255, 255, 0.85);
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.95rem;
    }

    .result-summary {
        max-width: 980px;
        margin: 0 auto;
        padding: 0 12px 32px;
    }

    .score-box {
        text-align: center;
        border: 2px dashed rgba(37, 99, 235, 0.35);
        border-radius: 18px;
        padding: 32px 24px;
        margin-bottom: 24px;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 18px 40px rgba(15, 33, 61, 0.08);
    }

    .score-title {
        font-size: 14px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #475569;
        margin-bottom: 10px;
    }

    .score-value {
        font-size: 64px;
        font-weight: 800;
        color: #0b2e54;
        letter-spacing: -0.02em;
    }

    .score-max {
        font-size: 26px;
        opacity: 0.55;
        margin-left: 12px;
    }

    .score-cards {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 28px;
    }

    .score-card {
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.90);
        border: 1px solid rgba(207, 221, 235, 0.75);
        padding: 18px 16px;
        box-shadow: 0 16px 42px rgba(12, 45, 73, 0.08);
        text-align: center;
    }

    .score-card__icon {
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: rgba(37, 99, 235, 0.12);
        color: #1e40af;
        margin-bottom: 10px;
        font-size: 18px;
    }

    .score-card--success .score-card__icon {
        background: rgba(34, 197, 94, 0.16);
        color: #166534;
    }

    .score-card--danger .score-card__icon {
        background: rgba(239, 68, 68, 0.16);
        color: #991b1b;
    }

    .score-card--warning .score-card__icon {
        background: rgba(245, 158, 11, 0.16);
        color: #92400e;
    }

    .score-card__label {
        font-size: 12px;
        color: #64748b;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 6px;
        display: block;
    }

    .score-card__value {
        font-size: 26px;
        font-weight: 800;
        color: #0f172a;
    }

    .part-analysis {
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(207, 221, 235, 0.75);
        padding: 18px 20px;
        box-shadow: 0 16px 42px rgba(12, 45, 73, 0.08);
    }

    .analysis-header {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 800;
        margin-bottom: 16px;
        color: #1e3a68;
    }

    .analysis-header i {
        font-size: 18px;
        color: #1d4ed8;
    }

    .analysis-row {
        display: grid;
        grid-template-columns: 1.2fr 1fr 2.6fr;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-top: 1px solid rgba(207, 221, 235, 0.8);
    }

    .analysis-row:first-child {
        border-top: none;
    }

    .analysis-label {
        font-weight: 700;
        color: #1f3a5b;
    }

    .analysis-meta {
        font-size: 13px;
        color: #475569;
        text-align: right;
    }

    .analysis-bar {
        height: 10px;
        border-radius: 999px;
        background: rgba(226, 232, 240, 0.8);
        overflow: hidden;
    }

    .analysis-bar__fill {
        height: 100%;
        background: linear-gradient(135deg, #2563eb 0%, #22c55e 100%);
    }

    .analysis-bar__fill--secondary {
        background: linear-gradient(135deg, #0ea5e9 0%, #7c3aed 100%);
    }

    .analysis-bar__fill--accent {
        background: linear-gradient(135deg, #f97316 0%, #e11d48 100%);
    }

    @@media (max-width: 991.98px) {
        .score-cards {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .analysis-row {
            grid-template-columns: 1.2fr 1fr 1fr;
        }
    }
</style>

<section class="content result-page">
    <div class="result-banner">
        <div class="result-banner__title">@Model.ExamTitle</div>
        <div class="result-banner__meta">
            <i class="fas fa-calendar-alt"></i>
            Hoàn thành lúc: @((Model.EndTime ?? DateTime.Now).ToString("hh:mm tt, dd/MM/yyyy"))
        </div>
    </div>

    <div class="result-summary">
        <div class="score-box">
            <div class="score-title">Điểm Reading Dự Kiến</div>
            <div class="score-value">@Model.ExpectedScore<span class="score-max">/495</span></div>
        </div>

        <div class="score-cards">
            <div class="score-card">
                <div class="score-card__icon"><i class="fas fa-stopwatch"></i></div>
                <div class="score-card__label">Thời gian làm bài</div>
                <div class="score-card__value">@((Model.EndTime ?? DateTime.Now) - Model.StartTime).ToString("hh\:mm")</div>
            </div>
            <div class="score-card score-card--success">
                <div class="score-card__icon"><i class="fas fa-check-circle"></i></div>
                <div class="score-card__label">Câu đúng</div>
                <div class="score-card__value">@Model.TotalCorrect</div>
            </div>
            <div class="score-card score-card--danger">
                <div class="score-card__icon"><i class="fas fa-times-circle"></i></div>
                <div class="score-card__label">Câu sai</div>
                <div class="score-card__value">@Model.TotalWrong</div>
            </div>
            <div class="score-card score-card--warning">
                <div class="score-card__icon"><i class="fas fa-minus-circle"></i></div>
                <div class="score-card__label">Bỏ qua</div>
                <div class="score-card__value">@Model.TotalSkipped</div>
            </div>
        </div>

        <div class="part-analysis">
            <div class="analysis-header">
                <i class="fas fa-chart-bar"></i>
                <span>Phân tích chi tiết từng phần</span>
            </div>
            <div class="analysis-list">
                @{
                    var partGroups = Model.StudentAnswers
                        .Where(sa => sa.Question != null)
                        .GroupBy(sa => sa.Question.PartNumber)
                        .ToDictionary(g => g.Key, g => new {
                            Total = g.Count(),
                            Correct = g.Count(sa => sa.IsCorrect)
                        });

                    int part5Total = partGroups.ContainsKey(5) ? partGroups[5].Total : 0;
                    int part5Correct = partGroups.ContainsKey(5) ? partGroups[5].Correct : 0;
                    int part6Total = partGroups.ContainsKey(6) ? partGroups[6].Total : 0;
                    int part6Correct = partGroups.ContainsKey(6) ? partGroups[6].Correct : 0;
                    int part7Total = partGroups.ContainsKey(7) ? partGroups[7].Total : 0;
                    int part7Correct = partGroups.ContainsKey(7) ? partGroups[7].Correct : 0;

                    Func<int,int,string> pct = (c,t) => t > 0 ? ((c * 100.0 / t)).ToString("F0") : "0";
                }

                <div class="analysis-row">
                    <div class="analysis-label">Part 5: Incomplete Sentences</div>
                    <div class="analysis-meta">@part5Correct / @part5Total câu (@pct(part5Correct, part5Total)%)</div>
                    <div class="analysis-bar"><div class="analysis-bar__fill" style="width:@pct(part5Correct, part5Total)%"></div></div>
                </div>
                <div class="analysis-row">
                    <div class="analysis-label">Part 6: Text Completion</div>
                    <div class="analysis-meta">@part6Correct / @part6Total câu (@pct(part6Correct, part6Total)%)</div>
                    <div class="analysis-bar"><div class="analysis-bar__fill analysis-bar__fill--secondary" style="width:@pct(part6Correct, part6Total)%"></div></div>
                </div>
                <div class="analysis-row">
                    <div class="analysis-label">Part 7: Reading Comprehension</div>
                    <div class="analysis-meta">@part7Correct / @part7Total câu (@pct(part7Correct, part7Total)%)</div>
                    <div class="analysis-bar"><div class="analysis-bar__fill analysis-bar__fill--accent" style="width:@pct(part7Correct, part7Total)%"></div></div>
                </div>
            </div>
        </div>
    </div>
</section>
