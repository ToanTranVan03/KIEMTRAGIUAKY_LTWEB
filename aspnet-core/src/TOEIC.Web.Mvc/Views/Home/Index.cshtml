@using TOEIC.Web.Startup
@{
    ViewBag.Title = L("HomePage");
    ViewBag.CurrentPageName = PageNames.Home;
}

@section scripts
{
    <script src="~/view-resources/Views/_Bundles/home-index.min.js" asp-append-version="true"></script>
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        color: white;
        padding: 80px 0;
        text-align: center;
    }
    .hero-section h1 {
        font-size: 3rem;
        font-weight: bold;
        margin-bottom: 20px;
    }
    .hero-section p {
        font-size: 1.2rem;
        margin-bottom: 30px;
    }
    .btn-toeic {
        background-color: #f59e0b;
        color: white;
        padding: 15px 30px;
        border: none;
        border-radius: 5px;
        font-size: 1.1rem;
        text-decoration: none;
        display: inline-block;
        margin: 10px;
    }
    .btn-toeic:hover {
        background-color: #d97706;
        color: white;
        text-decoration: none;
    }
    .features-section {
        padding: 60px 0;
        background-color: #f8fafc;
    }
    .feature-card {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
        margin-bottom: 30px;
    }
    .feature-card h3 {
        color: #1e3a8a;
        margin-bottom: 15px;
    }
    .feature-card p {
        color: #64748b;
    }
</style>

<div class="hero-section">
    <div class="container">
        <h1>Welcome to TOEIC Practice Tests</h1>
        <p>Prepare for your TOEIC exam with our comprehensive practice tests and study materials.</p>
        <a href="@Url.Action("Index", "Test")" class="btn-toeic">Start Practice Test</a>
        <a href="@Url.Action("Index", "Exams")" class="btn-toeic">View All Exams</a>
    </div>
</div>

<div class="features-section">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Real TOEIC Format</h3>
                    <p>Experience the actual TOEIC test format with listening and reading sections.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Instant Results</h3>
                    <p>Get your scores immediately after completing the test with detailed analysis.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <h3>Study Materials</h3>
                    <p>Access practice questions, tips, and strategies to improve your TOEIC score.</p>
                </div>
            </div>
        </div>
    </div>
