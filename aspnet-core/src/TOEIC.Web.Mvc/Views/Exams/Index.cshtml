            font-weight: 700;
        }

        .exam-card__stat i {
            color: #0f766e;
        }

        .exam-card__footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
        }

        .exam-card__footer .btn {
            flex: 1 1 130px;
            font-weight: 700;
        }

        .exam-empty {
            padding: 54px 24px;
            text-align: center;
            color: #5b7387;
        }

        .exam-empty i {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 82px;
            height: 82px;
            margin-bottom: 16px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e8f5f8 0%, #f2fbfd 100%);
            color: #14868a;
            font-size: 34px;
        }

        .exam-empty h3 {
            font-size: 24px;
            font-weight: 800;
            color: #16324f;
            margin-bottom: 10px;
        }

        .exam-empty p {
            margin: 0 auto;
            max-width: 520px;
            line-height: 1.7;
        }

        @@media (max-width: 991.98px) {
            .exam-admin-hero {
