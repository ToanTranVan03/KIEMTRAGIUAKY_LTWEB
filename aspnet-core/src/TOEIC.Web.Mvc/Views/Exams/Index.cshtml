            }

            .exam-admin-panel-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .library-hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .exam-grid {
                grid-template-columns: repeat(1, minmax(0, 1fr));
            }

            .exam-card__stats {
                grid-template-columns: 1fr;
            }

            .library-filters .form-row {
                flex-direction: column;
            }

            .library-filters .col-lg-5,
            .library-filters .col-lg-3 {
                max-width: 100%;
                flex: 1 1 100%;
            }
        }
    </style>
}

<section class="content exam-library">
    <div class="container-fluid">
        <div class="library-hero">
            <div class="library-hero__text">
                <h1>Thư viện Đề thi TOEIC Reading</h1>
                <p class="library-hero__subtitle">Hoàn thành các bài thi dưới đây để cải thiện kỹ năng đọc hiểu của bạn. Chúc bạn đạt kết quả tốt!</p>
            </div>
            <div class="library-hero__actions">
                <a href="@Url.Action("Upload")" class="btn btn-primary btn-lg">
                    <i class="fas fa-upload mr-2"></i>Upload đề thi mới
                </a>
            </div>
        </div>

        <div class="library-filters">
            <div class="form-row align-items-center">
                <div class="col-lg-5 mb-3 mb-lg-0">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0"><i class="fas fa-search"></i></span>
                        </div>
                        <input id="filterSearch" type="text" class="form-control border-left-0" placeholder="Tìm kiếm tên đề thi..." />
                    </div>
                </div>
                <div class="col-lg-3 mb-3 mb-lg-0">
                    <select id="filterStatus" class="form-control">
                        <option value="">Tất cả trạng thái</option>
                        <option value="draft">Mới</option>
                        <option value="published">Đã hoàn thành</option>
                    </select>
                </div>
                <div class="col-lg-3">
                    <select id="filterDifficulty" class="form-control">
                        <option value="">Độ khó: Tất cả</option>
                        <option value="easy">Dễ</option>
                        <option value="medium">Trung bình</option>
                        <option value="hard">Khó</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="exam-grid" id="examGrid">
            @if (Model.Count == 0)
            {
                <div class="exam-empty">
                    <i class="fas fa-folder-open"></i>
                    <h3>Chưa có đề thi nào</h3>
                    <p>Hãy upload đề thi mới để bắt đầu xây dựng thư viện đề thi TOEIC.</p>
                </div>
            }
            else
            {
                @foreach (var exam in Model)
                {
                    var isPublished = exam.Status == TOEIC.AppEntities.ExamStatus.Published;
                    var difficulty = exam.QuestionCount <= 60 ? "easy" : exam.QuestionCount <= 120 ? "medium" : "hard";
                    var difficultyLabel = difficulty == "easy" ? "Trung bình" : difficulty == "medium" ? "Khó" : "Rất khó";
                    var attemptCount = (int)Math.Ceiling(exam.QuestionCount * 1.1);
                    string attemptLabel;
                    if (attemptCount >= 1000)
                    {
                        attemptLabel = (attemptCount / 1000.0).ToString("0.0") + "k Lượt làm";
                    }
                    else
                    {
                        attemptLabel = attemptCount + " Lượt làm";
                    }

                    <div class="exam-card" data-title="@exam.Title" data-status="@(isPublished ? "published" : "draft")" data-difficulty="@difficulty">
                        <div class="exam-card__header">
                            <span class="exam-card__badge @(isPublished ? "exam-card__badge--success" : "exam-card__badge--new")">
                                <i class="fas @(isPublished ? "fa-check-circle" : "fa-star")"></i>
                                @(isPublished ? "Đã hoàn thành" : "MỚI")
                            </span>
                        </div>
                        <div class="exam-card__body">
                            <div class="exam-card__meta">
                                <span class="exam-card__meta-tag">Reading - Part 5,6,7</span>
                            </div>
                            <h3 class="exam-card__title">@exam.Title</h3>
                            <div class="exam-card__stats">
                                <div class="exam-card__stat">
                                    <i class="fas fa-clock"></i>
                                    <span>@exam.Duration phút</span>
                                </div>
                                <div class="exam-card__stat">
                                    <i class="fas fa-list-ol"></i>
                                    <span>@exam.QuestionCount câu</span>
                                </div>
                                <div class="exam-card__stat">
                                    <i class="fas fa-chart-line"></i>
                                    <span>@difficultyLabel</span>
                                </div>
                                <div class="exam-card__stat">
                                    <i class="fas fa-users"></i>
                                    <span>@attemptLabel</span>
                                </div>
                            </div>
                        </div>
                        <div class="exam-card__footer">
                            @if (isPublished)
                            {
                                <a href="@Url.Action("Detail", new { id = exam.Id })" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-info-circle mr-1"></i>Chi tiết
                                </a>
                                <a href="@Url.Action("Take", "Test", new { id = exam.Id })" class="btn btn-primary btn-sm">
                                    <i class="fas fa-redo mr-1"></i>Thi lại
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Detail", new { id = exam.Id })" class="btn btn-primary btn-sm">
                                    <i class="fas fa-play mr-1"></i>Bắt đầu làm bài
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

@section scripts {
    <script>
        function applyExamFilters() {
            var search = $('#filterSearch').val().trim().toLowerCase();
            var status = $('#filterStatus').val();
            var difficulty = $('#filterDifficulty').val();

            $('#examGrid .exam-card').each(function () {
                var $card = $(this);
                var title = $card.data('title').toString().toLowerCase();
                var cardStatus = $card.data('status');
                var cardDifficulty = $card.data('difficulty');

                var matchesSearch = !search || title.indexOf(search) !== -1;
                var matchesStatus = !status || cardStatus === status;
                var matchesDifficulty = !difficulty || cardDifficulty === difficulty;

                if (matchesSearch && matchesStatus && matchesDifficulty) {
                    $card.show();
                } else {
                    $card.hide();
                }
            });
        }

        $(document).ready(function () {
            $('#filterSearch').on('input', applyExamFilters);
            $('#filterStatus, #filterDifficulty').on('change', applyExamFilters);

            // Keep existing actions (publish/unpublish/delete) for admin table if needed
            $('.btn-publish').click(function () {
                var id = $(this).data('id');
                if (confirm('Bạn có chắc muốn xuất bản đề thi này?')) {
                    $.post('/Exams/Publish?id=' + id, function () {
                        location.reload();
                    });
                }
            });

            $('.btn-unpublish').click(function () {
                var id = $(this).data('id');
                if (confirm('Bạn có chắc muốn gỡ xuất bản đề thi này?')) {
                    $.post('/Exams/Unpublish?id=' + id, function () {
                        location.reload();
                    });
                }
            });

            $('.btn-delete').click(function () {
                var id = $(this).data('id');
                if (confirm('Xóa đề thi này? Tất cả câu hỏi và kết quả thi liên quan sẽ bị xóa.')) {
                    $.post('/Exams/Delete?id=' + id, function () {
                        location.reload();
                    });
                }
            });
        });
    </script>
}
