@using TOEIC.Web.Startup
@model List<TOEIC.Exams.Dto.ExamDto>
@{
    ViewBag.Title = "Quản lý đề thi";
    ViewBag.CurrentPageName = PageNames.Exams;

    var publishedCount = 0;
    foreach (var item in Model)
    {
        if (item.Status == TOEIC.AppEntities.ExamStatus.Published)
        {
            publishedCount++;
        }
    }

    var draftCount = Model.Count - publishedCount;
}

@section styles {
    <style>
        .exam-admin-page {
            padding: 24px 0 40px;
            background:
                radial-gradient(circle at top left, rgba(18, 146, 137, 0.14), transparent 30%),
                radial-gradient(circle at top right, rgba(37, 99, 235, 0.14), transparent 28%),
                linear-gradient(180deg, #f4f8fc 0%, #edf4f7 52%, #f8fbfd 100%);
            border-radius: 28px;
        }

        .exam-admin-hero {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            padding: 28px 30px;
            border-radius: 28px;
            background: linear-gradient(135deg, #153a5b 0%, #0f6d7a 58%, #23a4b5 100%);
            box-shadow: 0 28px 60px rgba(13, 48, 80, 0.18);
            color: #fff;
            position: relative;
            overflow: hidden;
            margin-bottom: 22px;
        }

        .exam-admin-hero::after {
            content: "";
            position: absolute;
            right: -90px;
            bottom: -130px;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.10);
        }

        .exam-admin-kicker {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.14);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .exam-admin-title {
            margin: 0 0 10px;
            font-size: 2.35rem;
            line-height: 1.08;
            font-weight: 800;
            letter-spacing: -0.04em;
        }

        .exam-admin-title i {
